APP_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=4000
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=10s

DATABASE_URL=postgres://sdd:sdd@localhost:5432/sdd_navigator?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=1
DB_QUERY_TIMEOUT=5s

JWT_SECRET=change-me-to-a-secure-secret-with-32-chars-min
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info

METRICS_ENABLED=true
OTEL_ENABLED=false
OTEL_SERVICE_NAME=sdd-navigator-api
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

DEMO_USER_EMAIL=test@test.com
DEMO_USER_PASSWORD=123456

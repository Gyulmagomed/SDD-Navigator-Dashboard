# =============================================================================
# SDD Navigator — переменные окружения
# Скопируйте в .env.local и подставьте значения. .env.local не коммитить.
# Полное описание: README.md → «Переменные окружения»
# =============================================================================

# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL (обязательно для типичного запуска)
# -----------------------------------------------------------------------------
# Полный URL бэкенда БЕЗ завершающего слэша, например:
#   http://localhost:4000
#   https://api.company.com
#
# Используется:
#   • Axios (lib/api/client.ts) — все запросы к REST API
#   • NextAuth (если authorize ходит во внешний /auth/login) — см. lib/auth.ts
#
# Для dev с MSW: URL должен совпасть с тем, под что написаны паттерны в
# mocks/handlers.ts (например rest.get("*/dashboard/stats")).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=

# -----------------------------------------------------------------------------
# NEXTAUTH_SECRET (обязательно)
# -----------------------------------------------------------------------------
# Секрет для подписи и проверки JWT сессии NextAuth.
# Сгенерировать (Linux/macOS/Git Bash):
#   openssl rand -base64 32
# В production — уникальный длинный секрет, не из примеров.
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=

# -----------------------------------------------------------------------------
# NEXTAUTH_URL (обязательно)
# -----------------------------------------------------------------------------
# Публично доступный URL этого Next-приложения (как его видит браузер).
# Примеры:
#   http://localhost:3000          — локальная разработка
#   https://app.company.com       — продакшен
#
# Важно для корректных редиректов OAuth/почты и части сценариев NextAuth.
# -----------------------------------------------------------------------------
NEXTAUTH_URL=

# -----------------------------------------------------------------------------
# ANALYZE (опционально)
# -----------------------------------------------------------------------------
# Установите true при запуске npm run analyze — включает @next/bundle-analyzer
# после сборки (анализ размера бандлов).
# Пример в .env.local:
#   ANALYZE=true
# -----------------------------------------------------------------------------
# ANALYZE=
